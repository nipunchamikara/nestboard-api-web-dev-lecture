generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  EXPIRED
  PENDING
}

enum PropertyType {
  HOUSE
  VILLA
  APARTMENT
  HOTEL
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bioTag      String?  @map("bio_tag")
  role        Role     @default(USER)
  createdAt   DateTime @default(now()) @map("created_at")

  properties Property[] @relation("VendorProperties")
  bookings   Booking[]

  passwordHash  String?        @map("password_hash")
  refreshTokens RefreshToken[]

  favorites Favorite[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Property {
  id          String       @id @default(uuid()) @db.Uuid
  vendorId    String       @map("vendor_id") @db.Uuid
  title       String
  description String       @db.Text
  address     String
  city        String
  type        PropertyType
  rating      Decimal      @default(0) @db.Decimal(3, 2)
  amenities   String[]     @default([])
  latitude    Float
  longitude   Float
  imageUrl    String       @map("image_url")
  minStay     String       @default("1 month") @map("min_stay")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  favoritedBy Favorite[]

  vendor    User       @relation("VendorProperties", fields: [vendorId], references: [id], onDelete: Cascade)
  roomTypes RoomType[]

  @@index([city])
  @@index([type])
  @@index([vendorId])
  @@map("properties")
}

model RoomType {
  id            String   @id @default(uuid()) @db.Uuid
  propertyId    String   @map("property_id") @db.Uuid
  name          String
  pricePerMonth Decimal  @map("price_per_month") @db.Decimal(10, 2)
  seatCapacity  Int      @map("seat_capacity")
  hasAC         Boolean  @default(false) @map("has_ac")
  isAvailable   Boolean  @default(true) @map("is_available")
  createdAt     DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms    Room[]

  @@index([propertyId])
  @@map("room_types")
}

model Room {
  id          String   @id @default(uuid()) @db.Uuid
  roomTypeId  String   @map("room_type_id") @db.Uuid
  roomLabel   String   @map("room_label")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")

  roomType RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([roomTypeId])
  @@map("rooms")
}

model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  roomId         String        @map("room_id") @db.Uuid
  seatNumber     Int           @map("seat_number")
  leaseStart     DateTime      @map("lease_start") @db.Date
  leaseEnd       DateTime      @map("lease_end") @db.Date
  durationMonths Int           @map("duration_months")
  totalAmount    Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  bookingStatus  BookingStatus @default(PENDING) @map("booking_status")
  createdAt      DateTime      @default(now()) @map("created_at")

  tenant User @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  room   Room @relation(fields: [roomId], references: [id], onDelete: Restrict)

  @@index([roomId, seatNumber, bookingStatus, leaseStart, leaseEnd])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("bookings")
}

model Favorite {
  userId     String   @map("user_id") @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@index([propertyId])
  @@map("favorites")
}
