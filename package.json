{
  "name": "nestboard-api",
  "version": "1.0.0",
  "description": "Backend server for NestBoard Application",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx prisma/seed.ts",
    "format": "npx prettier . --write",
    "format:check": "npx prettier . --check"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "multer": "^2.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
